NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
CORS_ORIGIN=https://asy-syifaa.com,https://www.asy-syifaa.com,https://erp.asy-syifaa.com
MEDIA_STORAGE_DIR=./storage/media
MEDIA_PUBLIC_BASE_URL=https://api.asy-syifaa.com
MEDIA_MAX_SIZE_MB=80
DB_BACKUP_KEEP_DAYS=14

# PPDB WhatsApp notification (optional)
PPDB_WA_NOTIFY_ENABLED=false
# Provider: generic | fonnte | wablas | waha
PPDB_WA_NOTIFY_PROVIDER=waha
PPDB_WA_NOTIFY_ENDPOINT=
PPDB_WA_NOTIFY_TOKEN=
PPDB_WA_SESSION=default
PPDB_WA_NOTIFY_TIMEOUT_MS=6000
PPDB_PUBLIC_WEBSITE_BASE_URL=https://asy-syifaa.com

